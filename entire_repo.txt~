                int total = length - text.length();

                switch (alignment) {
                    case 'l': 
                        text.append(total, ' ');
                        break;
                    case 'c':
                        text.insert(0, total / 2, ' ');
                        text.append(total - (total / 2), ' ');
                        break;

                    case 'r':
                        text.insert(0, total, ' ');
                        break;
